@{
    ViewData["Title"] = "Fintech Dashboard";
}

<div class="container mt-5">

    <h2 class="text-center mb-4">FintechPro Dashboard</h2>

    <div class="mb-3">
        <a class="btn btn-primary w-100" asp-controller="Accounts" asp-action="Create">
            Add Account
        </a>
    </div>

    <div class="mb-3">
        <a class="btn btn-success w-100" asp-controller="Accounts" asp-action="Index">
            View Accounts
        </a>
    </div>

    <div class="mb-3">
        <a class="btn btn-warning w-100" asp-controller="Transactions" asp-action="Create">
            Add Transaction
        </a>
    </div>

    <div class="mb-3">
        <a class="btn btn-info w-100" asp-controller="Portfolio" asp-action="Index">
            Portfolio
        </a>
    </div>

    <div class="mb-3">
        <a class="btn btn-dark w-100" asp-controller="Market" asp-action="Index">
            Market
        </a>
    </div>

</div>