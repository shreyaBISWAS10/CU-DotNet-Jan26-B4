@model IEnumerable<NorthWindCatalog.Web.DTOS.ProductDto>

<div class="container mt-5">

    <h2 class="fw-bold mb-4">🛒 Products</h2>

    <div class="row g-4">
        @foreach (var item in Model)
        {
            <div class="col-md-4">

                <div class="card shadow-sm h-100 p-3"
                     onclick="goToDetails('@item.ProductName', @item.UnitPrice, @item.UnitsInStock)"
                     style="cursor:pointer; border-radius:12px;">

                    <div class="card-body">

                        <!-- Product Name -->
                        <h5 class="fw-semibold mb-3">@item.ProductName</h5>

                        <!-- Price -->
                        <p class="mb-1 text-primary fw-bold fs-5">
                            ₹@item.UnitPrice
                        </p>

                        <!-- Stock -->
                        <p class="mb-2 text-muted">
                            Stock: @item.UnitsInStock
                        </p>

                        <!-- Divider -->
                        <hr />

                        <!-- Inventory -->
                        <p class="mb-0 fw-medium">
                            Inventory Value:
                            <span class="text-success">
                                ₹@item.InventoryValue
                            </span>
                        </p>

                    </div>

                </div>

            </div>
        }
    </div>

</div>