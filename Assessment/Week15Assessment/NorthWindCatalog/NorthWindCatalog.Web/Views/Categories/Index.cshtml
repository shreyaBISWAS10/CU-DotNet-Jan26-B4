@model IEnumerable<NorthWindCatalog.Web.DTOS.CategoryDto>

<div class="container mt-5">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold">📦 Product Categories</h2>

        <a href="/Summary/Index" class="btn btn-dark rounded-pill px-4">
            View Summary
        </a>
    </div>

    <div class="row g-4">
        @foreach (var item in Model)
        {
            <div class="col-md-4">
                <div class="card shadow-sm h-100 text-center p-3">

                    <img src="@item.ImageUrl"
                         class="card-img-top rounded"
                         style="height:200px; object-fit:cover;" />

                    <div class="card-body">
                        <h5 class="fw-semibold">@item.CategoryName</h5>

                        <a href="/Products/ByCategory?id=@item.CategoryId"
                           class="btn btn-primary mt-2 rounded-pill px-3">
                            Explore →
                        </a>
                    </div>

                </div>
            </div>
        }
    </div>

</div>